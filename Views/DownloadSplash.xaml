<Window x:Class="RobloxVault.Views.DownloadSplash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" Height="180"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True">
    <Border Background="#0D0D0F" CornerRadius="12"
            BorderBrush="#1E1E28" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.8" ShadowDepth="0"/>
        </Border.Effect>
        <StackPanel VerticalAlignment="Center" Margin="32,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="8" Height="8" CornerRadius="4"
                        Background="{DynamicResource AccentBrush}"
                        Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="Downloading Chromium"
                           Foreground="#E0E0EE" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Setting up the browser engine (~150MB)."
                       Foreground="#55557A" FontSize="12" Margin="0,0,0,20"
                       TextWrapping="Wrap"/>

            <ProgressBar IsIndeterminate="True" Height="4"
                         Background="#1A1A22"
                         Foreground="{DynamicResource AccentBrush}"
                         BorderThickness="0"/>

            <TextBlock Text="This only happens once."
                       Foreground="#303044" FontSize="10"
                       Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</Window>