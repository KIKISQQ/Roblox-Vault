<Window x:Class="RobloxVault.Views.AddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:RobloxVault.Converters"
        Title="Add Account" Height="320" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:NullToInverseVisibilityConverter x:Key="NullToInverseVisibilityConverter"/>
    </Window.Resources>

    <Border Background="#0D0D0F" CornerRadius="12"
            BorderBrush="#1E1E28" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="48" Opacity="0.75" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#1E1E28" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8" Height="8" Background="{DynamicResource AccentBrush}"
                                CornerRadius="4" Margin="0,0,10,0"/>
                        <TextBlock Text="Add Roblox Account"
                                   Foreground="#E0E0EE" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Style="{StaticResource IconButton}"
                            Foreground="#55557A" FontSize="13"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,0">

                <TextBlock Text="DISPLAY NAME" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#101016" CornerRadius="8"
                        BorderBrush="#222230" BorderThickness="1" Height="42">
                    <TextBox x:Name="DisplayNameBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#DCDCEC" FontSize="13"
                             Margin="14,0,14,0" VerticalAlignment="Center"
                             CaretBrush="{DynamicResource AccentBrush}"/>
                </Border>
                <TextBlock Text="(Optional) Leave blank to use Roblox username"
                           Foreground="#2A2A42" FontSize="11" Margin="2,6,0,18"/>

                <TextBlock Text=".ROBLOSECURITY COOKIE" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#101016" CornerRadius="8"
                        BorderBrush="#222230" BorderThickness="1" Height="42">
                    <TextBox x:Name="CookieBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#DCDCEC" FontSize="13"
                             Margin="14,0,14,0" VerticalAlignment="Center"
                             CaretBrush="{DynamicResource AccentBrush}"
                             AcceptsReturn="False"/>
                </Border>
                <TextBlock x:Name="HintText"
                           Text="Get this from your browser cookies on roblox.com"
                           Foreground="#2A2A42" FontSize="11" Margin="2,6,0,0"/>

            </StackPanel>

            <Border Grid.Row="2" BorderBrush="#1E1E28" BorderThickness="0,1,0,0">
                <Grid Margin="24,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}"
                                Padding="16,9"
                                FocusVisualStyle="{x:Null}"
                                Click="CancelButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="✕" FontSize="10" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="AddButton"
                                Style="{StaticResource AccentButton}"
                                Padding="18,9"
                                FocusVisualStyle="{x:Null}"
                                Click="AddButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="+" FontSize="14" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Add Account" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
