<Window x:Class="RobloxVault.Views.LaunchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launch" Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0D0D0F" CornerRadius="12"
            BorderBrush="#1E1E28" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="48" Opacity="0.75" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#1E1E28" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8" Height="8" Background="{DynamicResource AccentBrush}"
                                CornerRadius="4" Margin="0,0,10,0"/>
                        <TextBlock x:Name="HeaderText" Text="Launch Account"
                                   Foreground="#E0E0EE" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Style="{StaticResource IconButton}"
                            Foreground="#55557A" FontSize="13"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,0">

                <TextBlock Text="QUICK SELECT" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,0,0,10"/>
                <WrapPanel x:Name="PresetPanel" Margin="0,0,0,20">
                    <Button x:Name="BtnRogueLineage" Style="{StaticResource GhostButton}"
                            Content="Rogue Lineage" Margin="0,0,8,0"
                            Click="PresetGame_Click" Tag="3016661674" FontSize="12"
                            Padding="14,8"/>
                    <Button x:Name="BtnDeepwoken" Style="{StaticResource GhostButton}"
                            Content="Deepwoken" Margin="0,0,8,0"
                            Click="PresetGame_Click" Tag="4111023553" FontSize="12"
                            Padding="14,8"/>
                    <Button x:Name="BtnSearch" Style="{StaticResource GhostButton}"
                            Content="🔍 Search" Margin="0,0,0,0"
                            Click="SearchMode_Click" FontSize="12"
                            Padding="14,8"/>
                </WrapPanel>

                <TextBlock x:Name="PlaceIdLabel"
                           Text="PLACE ID" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,0,0,8"/>

                <Border x:Name="PlaceIdBorder" Background="#101016" CornerRadius="8"
                        BorderBrush="#222230" BorderThickness="1" Height="42">
                    <Grid>
                        <TextBlock x:Name="PlaceIdPlaceholder"
                                   Text="Enter a place ID..."
                                   Foreground="#2A2A42" FontSize="13"
                                   Margin="14,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False" Visibility="Collapsed"/>
                        <TextBox x:Name="PlaceIdBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#DCDCEC" FontSize="13"
                                 Margin="14,0,14,0" VerticalAlignment="Center"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 Text="3016661674"
                                 TextChanged="PlaceIdBox_TextChanged"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="GameNameText"
                           Text="Rogue Lineage"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="11" FontWeight="Medium"
                           Margin="2,8,0,0"/>

                <!-- Join Player -->
                <TextBlock Text="JOIN PLAYER" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,20,0,8"/>
                <Border Background="#101016" CornerRadius="8"
                        BorderBrush="#222230" BorderThickness="1" Height="42">
                    <Grid>
                        <TextBlock x:Name="UsernamePlaceholder"
                                   Text="Enter a Roblox username..."
                                   Foreground="#2A2A42" FontSize="13"
                                   Margin="14,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <TextBox x:Name="UsernameBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#DCDCEC" FontSize="13"
                                 Margin="14,0,14,0" VerticalAlignment="Center"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 TextChanged="UsernameBox_TextChanged"/>
                    </Grid>
                </Border>

            </StackPanel>

                <Border Grid.Row="2" BorderBrush="#1E1E28" BorderThickness="0,1,0,0">
                <Grid Margin="24,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}"
                                Padding="16,9" FocusVisualStyle="{x:Null}"
                                Click="CancelButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="✕" FontSize="10" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="OpenBrowserButton"
                                Style="{StaticResource GhostButton}"
                                Padding="10,9" Margin="0,0,8,0"
                                FocusVisualStyle="{x:Null}"
                                Click="OpenBrowserButton_Click">
                            <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="JoinPlayerButton"
                                Style="{StaticResource GhostButton}"
                                Padding="16,9" Margin="0,0,8,0"
                                IsEnabled="False"
                                FocusVisualStyle="{x:Null}"
                                Click="JoinPlayerButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="12" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Join Player" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource AccentButton}"
                                Padding="18,9" FocusVisualStyle="{x:Null}"
                                Click="LaunchButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▶" FontSize="10" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Launch" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
