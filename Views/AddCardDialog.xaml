<Window x:Class="RobloxVault.Views.AddCardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Card" Height="320" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0D0D0F" CornerRadius="12"
            BorderBrush="#1E1E28" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="48" Opacity="0.75" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#1E1E28" BorderThickness="0,0,0,1"
                    PreviewMouseDown="Border_MouseDown">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8" Height="8" Background="{DynamicResource AccentBrush}"
                                CornerRadius="4" Margin="0,0,10,0"/>
                        <TextBlock Text="Add Card" Foreground="#E0E0EE"
                                   FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,0">

                <TextBlock Text="CARD NAME" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#101016" CornerRadius="8"
                        BorderBrush="#222230" BorderThickness="1" Height="42">
                    <TextBox x:Name="CardNameBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#DCDCEC" FontSize="13"
                             Margin="14,0,14,0" VerticalAlignment="Center"
                             CaretBrush="{DynamicResource AccentBrush}"/>
                </Border>

                <TextBlock Text="COLOR" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,18,0,8"/>

                <WrapPanel x:Name="SwatchPanel" Margin="0,0,0,12">
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0"
                            Background="#8B5CF6" Cursor="Hand"
                            MouseDown="Swatch_Click" Tag="#8B5CF6">
                        <Border CornerRadius="6" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    </Border>
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0"
                            Background="#3B82F6" Cursor="Hand"
                            MouseDown="Swatch_Click" Tag="#3B82F6">
                        <Border CornerRadius="6" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    </Border>
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0"
                            Background="#22C55E" Cursor="Hand"
                            MouseDown="Swatch_Click" Tag="#22C55E">
                        <Border CornerRadius="6" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    </Border>
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0"
                            Background="#EAB308" Cursor="Hand"
                            MouseDown="Swatch_Click" Tag="#EAB308">
                        <Border CornerRadius="6" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    </Border>
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0"
                            Background="#E8433A" Cursor="Hand"
                            MouseDown="Swatch_Click" Tag="#E8433A">
                        <Border CornerRadius="6" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    </Border>
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0"
                            Background="#E8407A" Cursor="Hand"
                            MouseDown="Swatch_Click" Tag="#E8407A">
                        <Border CornerRadius="6" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    </Border>
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0"
                            Background="#06B6D4" Cursor="Hand"
                            MouseDown="Swatch_Click" Tag="#06B6D4">
                        <Border CornerRadius="6" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    </Border>
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,0,0"
                            Background="#FF6B35" Cursor="Hand"
                            MouseDown="Swatch_Click" Tag="#FF6B35">
                        <Border CornerRadius="6" BorderBrush="#FFFFFF" BorderThickness="0"/>
                    </Border>
                </WrapPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Custom hex:" Foreground="#484860" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Background="#101016" CornerRadius="6"
                            BorderBrush="#222230" BorderThickness="1"
                            Width="90" Height="26">
                        <TextBox x:Name="HexBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#DCDCEC" FontSize="11"
                                 Margin="6,0,6,0" VerticalAlignment="Center"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 MaxLength="7"
                                 TextChanged="HexBox_TextChanged"/>
                    </Border>
                    <Border x:Name="ColorPreview" Width="26" Height="26"
                            CornerRadius="6" Margin="8,0,0,0"
                            Background="#8B5CF6"/>
                </StackPanel>

            </StackPanel>

            <Border Grid.Row="2" BorderBrush="#1E1E28" BorderThickness="0,1,0,0">
                <Grid Margin="24,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Style="{StaticResource GhostButton}" Padding="16,9"
                                FocusVisualStyle="{x:Null}" Click="CancelButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="✕" FontSize="10" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource AccentButton}" Padding="18,9"
                                FocusVisualStyle="{x:Null}" Click="AddButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Add Card" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>