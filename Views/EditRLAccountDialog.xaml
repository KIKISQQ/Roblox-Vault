<Window x:Class="RobloxVault.Views.EditRLAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit RL Account" Height="480" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0D0D0F" CornerRadius="12"
            BorderBrush="#1E1E28" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="48" Opacity="0.75" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#1E1E28" BorderThickness="0,0,0,1"
                    Background="Transparent"
                    PreviewMouseDown="Border_MouseDown">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8" Height="8" Background="{DynamicResource AccentBrush}"
                                CornerRadius="4" Margin="0,0,10,0"/>
                        <TextBlock x:Name="HeaderText" Text="Edit — Rogue Lineage"
                                   Foreground="#E0E0EE" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,0">

                <TextBlock Text="DISPLAY NAME" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#101016" CornerRadius="8"
                        BorderBrush="#222230" BorderThickness="1" Height="42">
                    <TextBox x:Name="DisplayNameBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#DCDCEC" FontSize="13"
                             Margin="14,0,14,0" VerticalAlignment="Center"
                             CaretBrush="{DynamicResource AccentBrush}"/>
                </Border>
                <TextBlock Text="Leave blank to use Roblox username"
                           Foreground="#2A2A42" FontSize="11" Margin="2,6,0,16"/>

                <TextBlock Text="DESCRIPTION" Foreground="#303044"
                           FontSize="9.5" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#101016" CornerRadius="8"
                        BorderBrush="#222230" BorderThickness="1" Height="60">
                    <TextBox x:Name="DescriptionBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#DCDCEC" FontSize="13"
                             Margin="14,10,14,10"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto"
                             CaretBrush="{DynamicResource AccentBrush}"/>
                </Border>
                <TextBlock Text="Optional note visible on the card in all sections"
                           Foreground="#2A2A42" FontSize="11" Margin="2,6,0,16"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Width="8" Height="8" Background="{DynamicResource AccentBrush}"
                            CornerRadius="4" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="ROGUE LINEAGE NOTE" Foreground="#303044"
                               FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Background="#101016" CornerRadius="8"
                        BorderBrush="#2A1E10" BorderThickness="1" Height="60">
                    <TextBox x:Name="RLDescriptionBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#DCDCEC" FontSize="13"
                             Margin="14,10,14,10"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto"
                             CaretBrush="{DynamicResource AccentBrush}"/>
                </Border>
                <TextBlock Text="Character name, race, build, only shown in the Rogue Lineage section"
                           Foreground="#2A2A42" FontSize="11" Margin="2,6,0,0"/>

            </StackPanel>

            <Border Grid.Row="2" BorderBrush="#1E1E28" BorderThickness="0,1,0,0">
                <Grid Margin="24,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}"
                                Padding="16,9" FocusVisualStyle="{x:Null}"
                                Click="CancelButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="✕" FontSize="10" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Cancel" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="SaveButton"
                                Style="{StaticResource AccentButton}"
                                Padding="18,9" FocusVisualStyle="{x:Null}"
                                Click="SaveButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="✓" FontSize="12" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Save" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
